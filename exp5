<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz App with Timer</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            max-width: 700px;
            width: 100%;
            padding: 40px;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            color: #333;
            margin-bottom: 20px;
            font-size: 28px;
        }

        .timer-section {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        .timer-box {
            text-align: center;
            padding: 20px;
            background: #f0f4ff;
            border-radius: 10px;
            border: 2px solid #667eea;
            min-width: 120px;
        }

        .timer-label {
            font-size: 12px;
            color: #666;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .timer-value {
            font-size: 36px;
            font-weight: bold;
            color: #667eea;
        }

        .timer-box.warning .timer-value {
            color: #ff6b6b;
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.1);
            }
        }

        .warning-message {
            display: none;
            background: #ffe5e5;
            border-left: 4px solid #ff6b6b;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 5px;
            color: #ff6b6b;
            font-weight: 600;
            text-align: center;
        }

        .warning-message.show {
            display: block;
        }

        .question-container {
            margin-bottom: 30px;
        }

        .question {
            font-size: 18px;
            font-weight: 600;
            color: #333;
            margin-bottom: 20px;
            padding: 15px;
            background: #f9f9f9;
            border-left: 4px solid #667eea;
            border-radius: 5px;
        }

        .options {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .option {
            display: flex;
            align-items: center;
            padding: 12px 15px;
            border: 2px solid #ddd;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .option:hover {
            border-color: #667eea;
            background: #f0f4ff;
        }

        .option input[type="radio"] {
            margin-right: 12px;
            cursor: pointer;
            width: 18px;
            height: 18px;
        }

        .option label {
            cursor: pointer;
            flex-grow: 1;
            font-size: 16px;
            color: #333;
        }

        .option input[type="radio"]:checked + label {
            font-weight: 600;
            color: #d8c834;
        }

        .option.disabled {
            opacity: 0.6;
            cursor: not-allowed;
            background: #f5f5f5;
        }

        .option input[type="radio"]:disabled {
            cursor: not-allowed;
        }

        .result-display {
            display: none;
            text-align: center;
            padding: 30px;
            background: #f0f4ff;
            border-radius: 10px;
        }

        .result-display.show {
            display: block;
        }

        .result-score {
            font-size: 48px;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 10px;
        }

        .result-message {
            font-size: 20px;
            color: #333;
            margin-bottom: 20px;
        }

        .result-details {
            background: rgb(226, 207, 37);
            padding: 20px;
            border-radius: 8px;
            margin-top: 20px;
            text-align: left;
        }

        .result-item {
            padding: 10px 0;
            border-bottom: 1px solid #eee;
            font-size: 14px;
        }

        .result-item:last-child {
            border-bottom: none;
        }

        .correct {
            color: #51cf66;
            font-weight: 600;
        }

        .incorrect {
            color: #ff6b6b;
            font-weight: 600;
        }

        .quiz-section {
            display: none;
        }

        .quiz-section.active {
            display: block;
        }

        .button-group {
            display: flex;
            gap: 15px;
            margin-top: 20px;
            justify-content: center;
        }

        button {
            padding: 12px 30px;
            font-size: 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .submit-btn {
            background: #ceda34;
            color: white;
        }

        .submit-btn:hover:not(:disabled) {
            background: #5568d3;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .submit-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        .restart-btn {
            background: #d4e639;
            color: white;
        }

        .restart-btn:hover {
            background: #d8c72c;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(81, 207, 102, 0.4);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Quiz Application</h1>
        </div>

        <!-- Quiz Section -->
        <div class="quiz-section active">
            <div class="timer-section">
                <div class="timer-box" id="timerBox">
                    <div class="timer-label">Time Remaining</div>
                    <div class="timer-value" id="timerDisplay">10</div>
                </div>
            </div>

            <div class="warning-message" id="warningMessage">
                ⏰ Only 5 seconds remaining!
            </div>

            <div id="quizContent"></div>

            <div class="button-group">
                <button class="submit-btn" id="submitBtn">Submit Quiz</button>
            </div>
        </div>

        <!-- Results Section -->
        <div class="result-display" id="resultDisplay">
            <h2 style="color: #333; margin-bottom: 15px;">Quiz Completed!</h2>
            <div class="result-score" id="scoreDisplay">0/5</div>
            <div class="result-message" id="resultMessage">Good effort!</div>
            <div class="result-details" id="resultDetails"></div>
            <div class="button-group">
                <button class="restart-btn" onclick="restartQuiz()">Restart Quiz</button>
            </div>
        </div>
    </div>

    <script>
        // Quiz Data
        const quizData = [
            {
                id: 1,
                question: "What is the capital of France?",
                options: ["London", "Berlin", "Paris", "Madrid"],
                correct: 2
            },
            {
                id: 2,
                question: "Which planet is known as the Red Planet?",
                options: ["Venus", "Mars", "Jupiter", "Saturn"],
                correct: 1
            },
            {
                id: 3,
                question: "What is the largest ocean on Earth?",
                options: ["Atlantic Ocean", "Indian Ocean", "Arctic Ocean", "Pacific Ocean"],
                correct: 3
            },
            {
                id: 4,
                question: "Who wrote 'Romeo and Juliet'?",
                options: ["Jane Austen", "William Shakespeare", "Charles Dickens", "Mark Twain"],
                correct: 1
            },
            {
                id: 5,
                question: "What is the square root of 144?",
                options: ["10", "11", "12", "13"],
                correct: 2
            }
        ];

        // Timer Configuration
        const TOTAL_TIME = 10; // 10 seconds
        const WARNING_TIME = 5; // 5 seconds
        let timeRemaining = TOTAL_TIME;
        let timerInterval = null;
        let quizSubmitted = false;

        // Initialize quiz
        function initializeQuiz() {
            renderQuestions();
            startTimer();
        }

        // Render questions and options
        function renderQuestions() {
            const quizContent = document.getElementById('quizContent');
            quizContent.innerHTML = '';

            quizData.forEach((q, index) => {
                const questionHTML = document.createElement('div');
                questionHTML.className = 'question-container';
                questionHTML.innerHTML = `
                    <div class="question">Question ${q.id}: ${q.question}</div>
                    <div class="options" id="options-${q.id}">
                        ${q.options.map((option, optIndex) => `
                            <div class="option" id="option-${q.id}-${optIndex}">
                                <input 
                                    type="radio" 
                                    name="q${q.id}" 
                                    value="${optIndex}" 
                                    id="q${q.id}-opt${optIndex}"
                                    onchange="selectOption(${q.id}, ${optIndex})"
                                >
                                <label for="q${q.id}-opt${optIndex}">${option}</label>
                            </div>
                        `).join('')}
                    </div>
                `;
                quizContent.appendChild(questionHTML);
            });
        }

        // Start timer
        function startTimer() {
            timerInterval = setInterval(() => {
                timeRemaining--;
                updateTimerDisplay();

                // Show warning at 5 seconds
                if (timeRemaining === WARNING_TIME) {
                    document.getElementById('warningMessage').classList.add('show');
                    document.getElementById('timerBox').classList.add('warning');
                }

                // Auto-submit when time reaches zero
                if (timeRemaining <= 0) {
                    clearInterval(timerInterval);
                    submitQuiz();
                }
            }, 1000);
        }

        // Update timer display
        function updateTimerDisplay() {
            document.getElementById('timerDisplay').textContent = timeRemaining;
        }

        // Select option
        function selectOption(questionId, optionIndex) {
            if (quizSubmitted) return;
        }

        // Submit quiz
        function submitQuiz() {
            quizSubmitted = true;
            clearInterval(timerInterval);

            // Disable all inputs
            const allInputs = document.querySelectorAll('input[type="radio"]');
            allInputs.forEach(input => {
                input.disabled = true;
            });

            // Disable submit button
            document.getElementById('submitBtn').disabled = true;

            // Calculate score
            let score = 0;
            let results = [];

            quizData.forEach(q => {
                const selectedOption = document.querySelector(`input[name="q${q.id}"]:checked`);
                const selectedIndex = selectedOption ? parseInt(selectedOption.value) : -1;
                const isCorrect = selectedIndex === q.correct;

                if (isCorrect) score++;

                results.push({
                    question: q.question,
                    selectedAnswer: selectedIndex >= 0 ? q.options[selectedIndex] : 'Not answered',
                    correctAnswer: q.options[q.correct],
                    isCorrect: isCorrect
                });
            });

            // Show results
            displayResults(score, results);
        }

        // Display results
        function displayResults(score, results) {
            document.querySelector('.quiz-section').classList.remove('active');
            document.getElementById('resultDisplay').classList.add('show');

            document.getElementById('scoreDisplay').textContent = `${score}/5`;
            
            let message = '';
            if (score === 5) {
                message = 'Perfect! You got all questions correct! 🎉';
            } else if (score >= 3) {
                message = 'Great job! You did very well! 👏';
            } else if (score >= 1) {
                message = 'Good effort! Keep practicing! 📚';
            } else {
                message = 'Don\'t worry, try again! 💪';
            }
            document.getElementById('resultMessage').textContent = message;

            // Display detailed results
            let detailsHTML = '';
            results.forEach((result, index) => {
                const resultClass = result.isCorrect ? 'correct' : 'incorrect';
                const icon = result.isCorrect ? '✓' : '✗';
                detailsHTML += `
                    <div class="result-item">
                        <div style="margin-bottom: 8px;"><strong>Q${index + 1}: ${result.question}</strong></div>
                        <div>Your Answer: <span class="${resultClass}">${icon} ${result.selectedAnswer}</span></div>
                        ${!result.isCorrect ? `<div>Correct Answer: <span class="correct">✓ ${result.correctAnswer}</span></div>` : ''}
                    </div>
                `;
            });
            document.getElementById('resultDetails').innerHTML = detailsHTML;
        }

        // Restart quiz
        function restartQuiz() {
            // Reset variables
            timeRemaining = TOTAL_TIME;
            quizSubmitted = false;

            // Reset UI
            document.querySelector('.quiz-section').classList.add('active');
            document.getElementById('resultDisplay').classList.remove('show');
            document.getElementById('warningMessage').classList.remove('show');
            document.getElementById('timerBox').classList.remove('warning');
            document.getElementById('submitBtn').disabled = false;

            // Re-render and start
            initializeQuiz();
        }

        // Start quiz when page loads
        window.addEventListener('load', initializeQuiz);
    </script>
</body>
</html>
